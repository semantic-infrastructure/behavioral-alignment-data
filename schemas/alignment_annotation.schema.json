{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/semantic-infrastructure/behavioral-alignment-data/main/schemas/alignment_annotation.schema.json",
  "title": "Alignment Annotation",
  "description": "Machine-readable annotation structure for behavioral alignment evaluation in conversational systems.",
  "type": "object",
  "required": [
    "annotation_id",
    "conversation_item_id",
    "category",
    "label"
  ],
  "properties": {
    "annotation_id": {
      "type": "string",
      "description": "Unique identifier for the annotation.",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "conversation_item_id": {
      "type": "string",
      "description": "Reference to the associated conversation item.",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "category": {
      "type": "string",
      "description": "Primary annotation category.",
      "enum": [
        "structural",
        "semantic",
        "behavioral"
      ]
    },
    "label": {
      "type": "string",
      "description": "Primary annotation label."
    },
    "severity": {
      "type": "string",
      "description": "Optional severity classification.",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "description": "Optional annotation confidence score.",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "string",
      "description": "Optional annotation notes."
    },
    "evidence": {
      "type": "array",
      "description": "Observable conversational indicators supporting the annotation.",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "context_window": {
      "type": "object",
      "description": "Optional contextual interaction window.",
      "properties": {
        "previous_item_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "next_item_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "conversation_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "description": "Annotation review metadata.",
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "validated"
          ]
        },
        "reviewer": {
          "type": "string"
        },
        "review_date": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "string",
      "description": "Annotation schema version."
    }
  },
  "additionalProperties": false
}
